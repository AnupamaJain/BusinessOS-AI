{
  "name": "@business-os-ai/gateway-api",
  "version": "0.1.0",
  "private": true,
  "main": "./src/index.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc --project tsconfig.build.json",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "build:vercel": "esbuild src/vercel.ts --bundle --platform=node --target=node20 --format=cjs --outfile=api/index.js"
  },
  "dependencies": {
    "@business-os-ai/agent-core": "workspace:*",
    "@business-os-ai/auth": "workspace:*",
    "@business-os-ai/commerce": "workspace:*",
    "@business-os-ai/config": "workspace:*",
    "@business-os-ai/database": "workspace:*",
    "@business-os-ai/integrations": "workspace:*",
    "@business-os-ai/llm-gateway": "workspace:*",
    "@business-os-ai/mcp-business-tools": "workspace:*",
    "@business-os-ai/scheduler-worker": "workspace:*",
    "@business-os-ai/shared-types": "workspace:*",
    "@supabase/supabase-js": "^2.49.0",
    "@vercel/functions": "^2.0.0",
    "express": "^5.1.0",
    "qrcode": "^1.5.4",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^26.1.1",
    "@types/qrcode": "^1.5.6",
    "esbuild": "^0.24.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}