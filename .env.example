# ===========================
# Supabase (required)
# ===========================
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ===========================
# LLM Providers (one of these; on Vercel, OIDC → AI Gateway needs none)
# ===========================
# ANTHROPIC_API_KEY=sk-ant-...
# AI_GATEWAY_API_KEY=vck_...           # Vercel AI Gateway key (alternative to OIDC)
# OPENAI_API_KEY=sk-...
# AI_GATEWAY_MODEL=anthropic/claude-sonnet-4.5
# EMBEDDING_MODEL=openai/text-embedding-3-small

# ===========================
# Twilio WhatsApp (easiest — sandbox needs no business verification)
# Provider priority: Twilio → Meta → Mock. Set these to use Twilio.
# ===========================
# TWILIO_ACCOUNT_SID=ACxxxxxxxx
# TWILIO_AUTH_TOKEN=your-twilio-auth-token
# TWILIO_WHATSAPP_NUMBER=+14155238886        # sandbox number, or your WhatsApp sender
# TWILIO_WEBHOOK_URL=https://saarthione-api.vercel.app/webhooks/twilio  # exact URL for signature check

# ===========================
# Provider selection: run BOTH at once — each conversation is answered on the
# channel it arrived on. Optional override: WHATSAPP_PROVIDER = meta | twilio | mock
# (default preference: Meta when its creds are set, else Twilio).
# WHATSAPP_PROVIDER=meta

# Meta / WhatsApp Business (works alongside Twilio)
# ===========================
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret          # enables webhook HMAC verification
META_VERIFY_TOKEN=your-webhook-verify-token
META_WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
META_WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token

# ===========================
# Razorpay (optional — payment links)
# ===========================
# Test mode = same API, just use a test key (rzp_test_...). Swap to rzp_live_...
# for production — no code change. Pay test links with UPI success@razorpay or
# card 4111 1111 1111 1111. Configure a webhook (payment_link.paid) per mode.
# RAZORPAY_KEY_ID=rzp_test_...        # rzp_test_ = sandbox, rzp_live_ = production
# RAZORPAY_KEY_SECRET=...
# RAZORPAY_WEBHOOK_SECRET=...          # from the Test-mode (or Live-mode) webhook

# ===========================
# Application
# ===========================
APP_BASE_URL=http://localhost:3001
DEFAULT_ORG_ID=11111111-1111-1111-1111-111111111111
INTERNAL_API_KEY=generate-a-long-random-string
# CRON_SECRET=set-on-vercel-for-cron-auth
# CORS_ORIGINS=https://your-dashboard-domain

# ===========================
# Feature Flags
# ===========================
ENABLE_MOCK_WHATSAPP=false
ENABLE_DRY_RUN_AUTOMATION=false

# ===========================
# Email automation (optional — Resend)
# ===========================
# RESEND_API_KEY=re_...
# EMAIL_FROM=onboarding@resend.dev
# EMAIL_FROM_NAME=SaarthiOne

# ===========================
# Documents / public links
# ===========================
# PUBLIC_GATEWAY_URL=https://saarthione-api.vercel.app

# Web dashboard — Meta Embedded Signup (self-serve WhatsApp onboarding)
# VITE_META_APP_ID=
# VITE_META_CONFIG_ID=

# ===========================
# Hardening (optional)
# ===========================
# ENCRYPTION_KEY=<openssl rand -hex 32>          # encrypts WhatsApp tokens + contact phone numbers at rest (blind-indexed for lookup)
# ALERT_EMAIL=ops@yourcompany.com                 # ops alerts (agent crashes, WhatsApp token expiry) — throttled to 1/hour/key; needs RESEND_API_KEY
# REQUIRE_MERCHANT_APPROVAL=true                   # gate self-serve signups → onboarding_status 'pending_review' until you activate them (default: auto-active)

# ── Voice notes (optional) ──
# Inbound voice → text uses GROQ_API_KEY (Groq Whisper, separate free quota), falling back to GOOGLE_API_KEY (Gemini).
# Outbound voice replies (spoken answers when the customer sent a voice note) use Google Cloud Text-to-Speech:
# GOOGLE_CLOUD_TTS_API_KEY=...                     # enable Cloud TTS (v1 text:synthesize) — voice replies stay off until set
# TTS_LANGUAGE_CODE=en-IN                          # default voice language (e.g. en-IN, hi-IN)
# TTS_VOICE_NAME=                                   # optional specific voice (e.g. en-IN-Wavenet-D); blank = API picks for the language
# GROQ_WHISPER_MODEL=whisper-large-v3-turbo        # optional override for the inbound STT model
# LLM_MONTHLY_COST_CAP_USD=50                     # per-org monthly LLM budget (0 = unlimited)
# REENGAGEMENT_TEMPLATE=hello_world               # approved template for cold-lead follow-ups
# DASHBOARD_URL=https://saarthione.vercel.app
# Platform billing (Stripe)
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_STARTER=price_...
# STRIPE_PRICE_GROWTH=price_...
# STRIPE_PRICE_SCALE=price_...

# ===========================
# HubSpot CRM (optional, two-way sync)
# ===========================
# HUBSPOT_ACCESS_TOKEN=pat-...                    # private-app token; pushes qualified leads → HubSpot contacts+deals
# HUBSPOT_WEBHOOK_SECRET=<app client secret>      # validates inbound HubSpot webhooks (v3 signature) at /webhooks/hubspot

# ===========================
# Instagram / Messenger channel (optional)
# ===========================
# INSTAGRAM_PAGE_ID=<page or IG-linked id>        # enables the /webhooks/instagram channel (same agent pipeline)
# INSTAGRAM_PAGE_ACCESS_TOKEN=EAAG...             # Page access token used to send Direct/Messenger replies
# INSTAGRAM_VERIFY_TOKEN=<webhook verify token>   # defaults to META_VERIFY_TOKEN if unset
# INSTAGRAM_CHANNEL=instagram                      # 'instagram' | 'messenger'
